@model IEnumerable<MyApp.Web.Models.ViewModels.ClienteVM>
@{ ViewBag.Title = "Clientes"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<h2>Clientes</h2>
<p><a class="btn btn-primary" href="@Url.Action("Create")">Nuevo</a></p>
<table class="table table-bordered">
<thead><tr><th>Nombre</th><th>Correo</th><th>Activo</th><th></th></tr></thead>
<tbody>
@foreach (var item in Model) {
<tr>
<td>@item.Nombre</td><td>@item.Correo</td><td>@item.Activo</td>
<td>
@if (item.PuedeEditar) { <a class="btn btn-sm btn-warning" href="@Url.Action("Edit", new { id = item.Id })">Editar</a> }
@if (item.PuedeEliminar) { <a class="btn btn-sm btn-danger" href="@Url.Action("Delete", new { id = item.Id })">Eliminar</a> }
</td>
</tr>
}
</tbody>
</table>
